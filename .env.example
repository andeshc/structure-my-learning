PORT=3001

# Set to /data/StructureMyLearning.db on Railway (volume mount at /data)
DATABASE_PATH=./data/StructureMyLearning.db

JWT_SECRET=change_me_to_a_long_random_string
JWT_REFRESH_SECRET=change_me_to_another_long_random_string

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# OPENAI_GUIDE_MODEL=gpt-4o        # model for guide outline generation (defaults to OPENAI_MODEL)
# OPENAI_CONTENT_MODEL=gpt-4o      # model for subtopic content generation (defaults to OPENAI_MODEL)
OPENAI_IMAGE_MODEL=gpt-image-2

# Novita AI (set AI_PROVIDER=novita to use)
# NOVITA_API_KEY=your_novita_api_key
# NOVITA_MODEL=meta-llama/llama-3.1-8b-instruct
# NOVITA_GUIDE_MODEL=meta-llama/llama-3.1-8b-instruct   # defaults to NOVITA_MODEL
# NOVITA_CONTENT_MODEL=meta-llama/llama-3.1-8b-instruct # defaults to NOVITA_MODEL

# Together AI (set AI_PROVIDER=together to use)
# TOGETHER_API_KEY=your_together_api_key
# TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo
# TOGETHER_GUIDE_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo   # defaults to TOGETHER_MODEL
# TOGETHER_CONTENT_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo # defaults to TOGETHER_MODEL

FAL_KEY=your_fal_api_key

# Image generation models (via fal.ai)
# Supported: fal-ai/nano-banana-2 | xai/grok-imagine-image/quality/text-to-image | openai/gpt-image-2
GUIDE_ILLUSTRATION_MODEL=xai/grok-imagine-image/quality/text-to-image
TOPIC_ILLUSTRATION_MODEL=fal-ai/nano-banana-2

# Backblaze B2 storage + Cloudflare CDN (leave blank to use local disk fallback)
B2_APPLICATION_KEY_ID=your_b2_key_id
B2_APPLICATION_KEY=your_b2_application_key
B2_BUCKET_NAME=your_bucket_name
B2_BUCKET_REGION=us-west-004   # match your B2 bucket region
CDN_URL=https://cdn.yourdomain.com   # Cloudflare CNAME pointing at B2

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/github/callback

FACEBOOK_CLIENT_ID=your_facebook_client_id
FACEBOOK_CLIENT_SECRET=your_facebook_client_secret
FACEBOOK_CALLBACK_URL=http://localhost:3001/api/auth/facebook/callback

# Apple Sign In — APPLE_PRIVATE_KEY is the .p8 contents with newlines escaped as \n
APPLE_CLIENT_ID=your_apple_client_id
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_PRIVATE_KEY=your_apple_private_key
APPLE_CALLBACK_URL=https://localhost:3001/api/auth/apple/callback

LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_CALLBACK_URL=http://localhost:3001/api/auth/linkedin/callback

MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_CALLBACK_URL=http://localhost:3001/api/auth/microsoft/callback

# Comma-separated list of allowed CORS origins
CLIENT_URL=http://localhost:5173

# Canonical frontend URL used for OAuth redirects (defaults to first entry of CLIENT_URL)
# Set this explicitly when CLIENT_URL contains multiple origins
# APP_URL=https://yourdomain.com

# AI generation rate limit per user per hour (default: 200)
AI_RATE_LIMIT_PER_HOUR=200

# Auth endpoint rate limit per IP per 15 minutes (default: 300)
AUTH_RATE_LIMIT_PER_15_MIN=300

# Model cost rates in USD per million tokens — JSON map of model ID to {input, output}
# Overrides built-in defaults. Unspecified models fall back to defaults.
# MODEL_RATES={"claude-sonnet-4-6":{"input":3.00,"output":15.00},"gpt-4o":{"input":2.50,"output":10.00}}
