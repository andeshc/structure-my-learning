PORT=3001

# Set to /data/StructureMyLearning.db on Railway (volume mount at /data)
DATABASE_PATH=./data/StructureMyLearning.db

JWT_SECRET=change_me_to_a_long_random_string
JWT_REFRESH_SECRET=change_me_to_another_long_random_string

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=gpt-image-2

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/github/callback

# Comma-separated list of allowed CORS origins
CLIENT_URL=http://localhost:5173

# AI generation rate limit per user per hour (default: 200)
AI_RATE_LIMIT_PER_HOUR=200

# Auth endpoint rate limit per IP per 15 minutes (default: 300)
AUTH_RATE_LIMIT_PER_15_MIN=300
